{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Adversarial Review Arena",
  "version": "0.1.0",
  "identifier": "com.nekowasabi.adversarial-review-arena",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "Adversarial Review Arena",
    "windows": [
      {
        "title": "Adversarial Review Arena",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "claude",
          "command": "claude",
          "args": true
        },
        {
          "name": "codex",
          "command": "codex",
          "args": true
        }
      ]
    }
  }
}